# Server
PORT=3000
NODE_ENV=development

# Database (local PostgreSQL)
DATABASE_URL=postgresql://postgres:yourpassword@localhost:5432/caissa

# CORS – set to the URL where the frontend runs (default: http://localhost:5173)
CORS_ORIGIN=http://localhost:5173

# Supabase – get these from your Supabase project dashboard under Settings > API
SUPABASE_URL=https://<your-project-ref>.supabase.co
SUPABASE_SERVICE_ROLE_KEY=<your-service-role-key>

# Supabase JWT secrets – found under Settings > API > JWT Settings
SUPABASE_JWT_SECRET=<your-jwt-secret>
SUPABASE_JWT_PUBLIC_KEY="-----BEGIN PUBLIC KEY-----\n<your-public-key>\n-----END PUBLIC KEY-----"
