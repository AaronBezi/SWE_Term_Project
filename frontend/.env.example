# Supabase – get these from your Supabase project dashboard under Settings > API
VITE_SUPABASE_URL=https://<your-project-ref>.supabase.co
VITE_SUPABASE_ANON_KEY=<your-anon-public-key>

# Backend API URL – where the Express server is running (default: http://localhost:3000)
VITE_API_URL=http://localhost:3000
