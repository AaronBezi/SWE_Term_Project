# Playwright E2E test credentials
# Create a regular learner account in Supabase and put its credentials here
PLAYWRIGHT_TEST_EMAIL=learner@example.com
PLAYWRIGHT_TEST_PASSWORD=yourpassword

# Optional: an admin account for admin panel tests (tests/admin.spec.js)
# If omitted, admin tests are automatically skipped
PLAYWRIGHT_ADMIN_EMAIL=admin@example.com
PLAYWRIGHT_ADMIN_PASSWORD=yourpassword
